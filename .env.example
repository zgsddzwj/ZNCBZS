# ============================================================
# 智能财报助手 - 环境变量配置模板
# 复制此文件为 .env 并填写实际值
# ============================================================

# 应用基础配置
APP_NAME=智能财报助手
APP_VERSION=1.0.0
DEBUG=False
APP_ENV=production

# 服务地址
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=http://localhost:3000

# CORS 配置（逗号分隔多个源）
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# TrustedHost 配置（生产环境应设置为具体域名，逗号分隔）
ALLOWED_HOSTS=["*"]

# 安全密钥（必须修改！）
SECRET_KEY=your-secret-key-here-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-here-change-in-production
ENCRYPTION_KEY=

# JWT 配置
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# 初始管理员配置（首次启动时自动创建）
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=change-this-to-a-strong-password

# 大模型配置
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4-turbo-preview

DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_EMBED_MODEL=deepseek-embedding
LOCAL_EMBED_MODEL=shibing624/text2vec-base-chinese

# 数据库配置
DATABASE_URL=sqlite:///./data/zncbzs.db
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# 知识图谱数据库 (Neo4j)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password-here

# 向量数据库 (Milvus)
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=financial_reports

# 文件存储
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE=104857600

# 日志配置
LOG_LEVEL=INFO
LOG_DIR=./logs

# 性能配置
MAX_CONCURRENT_REQUESTS=100
REQUEST_TIMEOUT=30
CACHE_ENABLED=True

# OCR 配置
TESSERACT_CMD=/usr/bin/tesseract
OCR_LANG=chi_sim+eng
