# ===========================================
# Docker Compose 环境变量模板
# 使用方法: 复制为 .env 并替换所有密码为强随机值
#   cp .env.docker.example .env
# ===========================================

# --- Neo4j ---
NEO4J_PASSWORD=change-this-to-a-strong-password

# --- MinIO ---
MINIO_ACCESS_KEY=change-this-access-key
MINIO_SECRET_KEY=change-this-to-a-strong-secret

# --- 后端应用密钥 (与 .env 一致) ---
SECRET_KEY=generate-a-strong-secret-key
JWT_SECRET_KEY=generate-a-strong-jwt-secret
DEEPSEEK_API_KEY=your-deepseek-api-key
DATABASE_URL=sqlite:///./data/zncbzs.db
REDIS_URL=redis://redis:6379/0

# --- 初始管理员 ---
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=change-this-to-a-strong-password

# --- 应用配置 ---
DEBUG=False
APP_ENV=production
